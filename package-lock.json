{
  "name": "0xclaw",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "0xclaw",
      "version": "0.1.0",
      "workspaces": [
        "packages/*"
      ],
      "engines": {
        "node": ">=20"
      }
    },
    "node_modules/@0xclaw/adapters": {
      "resolved": "packages/adapters",
      "link": true
    },
    "node_modules/@0xclaw/cli": {
      "resolved": "packages/cli",
      "link": true
    },
    "node_modules/@0xclaw/core": {
      "resolved": "packages/core",
      "link": true
    },
    "node_modules/@0xclaw/loops": {
      "resolved": "packages/loops",
      "link": true
    },
    "node_modules/@0xclaw/profiles": {
      "resolved": "packages/profiles",
      "link": true
    },
    "packages/adapters": {
      "name": "@0xclaw/adapters",
      "version": "0.1.0"
    },
    "packages/cli": {
      "name": "@0xclaw/cli",
      "version": "0.1.0",
      "bin": {
        "0xclaw": "src/index.mjs"
      }
    },
    "packages/core": {
      "name": "@0xclaw/core",
      "version": "0.1.0"
    },
    "packages/loops": {
      "name": "@0xclaw/loops",
      "version": "0.1.0"
    },
    "packages/profiles": {
      "name": "@0xclaw/profiles",
      "version": "0.1.0"
    }
  }
}
